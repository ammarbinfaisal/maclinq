{
  "title": "Maclinq - Remote Keyboard Toggle",
  "rules": [
    {
      "description": "F8: Toggle maclinq (send input to the remote endpoint)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "f8"
          },
          "to": [
            {
              "shell_command": "/bin/bash -c 'echo -ne \"\\x01\" | /usr/bin/nc -U /tmp/maclinq.sock'"
            }
          ]
        }
      ]
    },
    {
      "description": "Shift+F8: Force OFF maclinq",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "f8",
            "modifiers": {
              "mandatory": ["shift"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "/bin/bash -c 'echo -ne \"\\x03\" | /usr/bin/nc -U /tmp/maclinq.sock'"
            }
          ]
        }
      ]
    }
  ]
}
